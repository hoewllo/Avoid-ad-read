{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 15
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default Configuration",
      "description": "Default build configuration with MinGW",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build/default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install",
        "BUILD_TESTS": "OFF",
        "BUILD_DOCS": "OFF",
        "ENABLE_ZLIB": "ON",
        "ENABLE_ICONV": "ON",
        "ENABLE_SYSTEM_ZIP": "ON"
      },
      "environment": {
        "CC": "gcc",
        "CXX": "g++"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug Configuration",
      "description": "Debug build with symbols",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install-debug",
        "BUILD_TESTS": "ON",
        "BUILD_DOCS": "OFF",
        "ENABLE_ZLIB": "ON",
        "ENABLE_ICONV": "ON",
        "ENABLE_SYSTEM_ZIP": "ON"
      },
      "environment": {
        "CC": "gcc",
        "CXX": "g++"
      }
    },
    {
      "name": "release",
      "displayName": "Release Configuration",
      "description": "Release build with optimizations",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install-release",
        "BUILD_TESTS": "OFF",
        "BUILD_DOCS": "OFF",
        "ENABLE_ZLIB": "ON",
        "ENABLE_ICONV": "ON",
        "ENABLE_SYSTEM_ZIP": "ON",
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON"
      },
      "environment": {
        "CC": "gcc",
        "CXX": "g++"
      }
    },
    {
      "name": "msvc",
      "displayName": "MSVC Configuration",
      "description": "Build with Visual Studio generator",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/msvc",
      "architecture": "x64",
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install-msvc",
        "BUILD_TESTS": "OFF",
        "BUILD_DOCS": "OFF",
        "ENABLE_ZLIB": "ON",
        "ENABLE_ICONV": "ON",
        "ENABLE_SYSTEM_ZIP": "ON",
        "CMAKE_CONFIGURATION_TYPES": "Release;Debug"
      }
    },
    {
      "name": "minimal",
      "displayName": "Minimal Configuration",
      "description": "Minimal build without optional dependencies",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build/minimal",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install-minimal",
        "BUILD_TESTS": "OFF",
        "BUILD_DOCS": "OFF",
        "ENABLE_ZLIB": "OFF",
        "ENABLE_ICONV": "OFF",
        "ENABLE_SYSTEM_ZIP": "OFF"
      },
      "environment": {
        "CC": "gcc",
        "CXX": "g++"
      }
    },
    {
      "name": "mingw64",
      "displayName": "MinGW-w64 Configuration",
      "description": "Build with MinGW-w64 (64-bit)",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build/mingw64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install-mingw64",
        "BUILD_TESTS": "OFF",
        "BUILD_DOCS": "OFF",
        "ENABLE_ZLIB": "ON",
        "ENABLE_ICONV": "ON",
        "ENABLE_SYSTEM_ZIP": "ON"
      },
      "environment": {
        "CC": "x86_64-w64-mingw32-gcc",
        "CXX": "x86_64-w64-mingw32-g++"
      }
    },
    {
      "name": "mingw32",
      "displayName": "MinGW-w32 Configuration",
      "description": "Build with MinGW-w64 (32-bit)",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build/mingw32",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install-mingw32",
        "BUILD_TESTS": "OFF",
        "BUILD_DOCS": "OFF",
        "ENABLE_ZLIB": "ON",
        "ENABLE_ICONV": "ON",
        "ENABLE_SYSTEM_ZIP": "ON"
      },
      "environment": {
        "CC": "i686-w64-mingw32-gcc",
        "CXX": "i686-w64-mingw32-g++"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "displayName": "Build Default",
      "description": "Build with default configuration"
    },
    {
      "name": "debug",
      "configurePreset": "debug",
      "displayName": "Build Debug",
      "description": "Build debug version"
    },
    {
      "name": "release",
      "configurePreset": "release",
      "displayName": "Build Release",
      "description": "Build release version"
    },
    {
      "name": "msvc",
      "configurePreset": "msvc",
      "displayName": "Build MSVC",
      "description": "Build with MSVC"
    },
    {
      "name": "minimal",
      "configurePreset": "minimal",
      "displayName": "Build Minimal",
      "description": "Build minimal version"
    },
    {
      "name": "mingw64",
      "configurePreset": "mingw64",
      "displayName": "Build MinGW64",
      "description": "Build with MinGW-w64 (64-bit)"
    },
    {
      "name": "mingw32",
      "configurePreset": "mingw32",
      "displayName": "Build MinGW32",
      "description": "Build with MinGW-w64 (32-bit)"
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "debug",
      "displayName": "Test Default",
      "description": "Run tests with debug configuration"
    }
  ]
}
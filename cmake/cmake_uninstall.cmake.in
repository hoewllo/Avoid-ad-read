# 卸载脚本
if(NOT EXISTS "@CMAKE_BINARY_DIR@/install_manifest.txt")
    message(FATAL_ERROR "Cannot find install manifest: @CMAKE_BINARY_DIR@/install_manifest.txt")
endif()

file(READ "@CMAKE_BINARY_DIR@/install_manifest.txt" files)
string(REGEX REPLACE "\n" ";" files "${files}")

foreach(file ${files})
    message(STATUS "Uninstalling $ENV{DESTDIR}${file}")
    
    if(EXISTS "$ENV{DESTDIR}${file}")
        execute_process(
            COMMAND @CMAKE_COMMAND@ -E remove "$ENV{DESTDIR}${file}"
            OUTPUT_VARIABLE rm_out
            RESULT_VARIABLE rm_retval
        )
        
        if(NOT ${rm_retval} EQUAL 0)
            message(FATAL_ERROR "Failed to remove $ENV{DESTDIR}${file}")
        endif()
    else()
        message(STATUS "File $ENV{DESTDIR}${file} does not exist")
    endif()
endforeach()

# 尝试删除空目录
set(dirs_to_check
    "@CMAKE_INSTALL_PREFIX@/bin"
    "@CMAKE_INSTALL_PREFIX@/lib"
    "@CMAKE_INSTALL_PREFIX@/include/epub_cleaner"
    "@CMAKE_INSTALL_PREFIX@/share/epub_cleaner"
    "@CMAKE_INSTALL_PREFIX@/lib/cmake/epub_cleaner"
)

foreach(dir ${dirs_to_check})
    if(EXISTS "${dir}")
        file(GLOB files_in_dir "${dir}/*")
        list(LENGTH files_in_dir file_count)
        
        if(${file_count} EQUAL 0)
            execute_process(
                COMMAND @CMAKE_COMMAND@ -E remove_directory "${dir}"
                OUTPUT_VARIABLE rm_out
                RESULT_VARIABLE rm_retval
            )
            
            if(${rm_retval} EQUAL 0)
                message(STATUS "Removed empty directory: ${dir}")
            endif()
        endif()
    endif()
endforeach()

message(STATUS "Uninstall completed successfully")